---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offices = [
  {
    flag: '🇺🇸',
    country: 'USA',
    role: 'Legal entity — PROOQ LLC',
    address: ['Elmwood Park', 'Chicago, IL 60707-2003'],
    phones: [
      { label: '+1 708 540 0888', tel: '+17085400888' },
      { label: '+1 708 527 5567', tel: '+17085275567' },
    ],
    wa: '+17085400888',
    waText: 'Hello%2C%20I%27m%20interested%20in%20SuiteHub%20from%20USA',
  },
  {
    flag: '🇵🇦',
    country: 'Panama',
    role: 'Local operations — PROOQ S.A.',
    address: ['Vía Argentina', 'Bella Vista, Panama City'],
    phones: [
      { label: '+507 6632-6006', tel: '+50766326006' },
    ],
    wa: '50766326006',
    waText: 'Hello%2C%20I%27m%20interested%20in%20SuiteHub',
  },
  {
    flag: '🇪🇸',
    country: 'Spain',
    role: 'Soft launch — remote operation',
    address: ['Calle La Línea 15', 'Puerto Real, Andalucía 11510'],
    phones: [
      { label: '+34 641 246 302', tel: '+34641246302' },
      { label: '+34 742 067 178', tel: '+34742067178' },
    ],
    wa: '34641246302',
    waText: 'Hello%2C%20I%27m%20interested%20in%20SuiteHub%20from%20Spain',
  },
  {
    flag: '🇻🇪',
    country: 'Venezuela',
    role: 'Soft launch — remote operation',
    address: null,
    phones: [
      { label: '+58 424-8820040', tel: '+584248820040', note: 'Anzoátegui · Daniel Velásquez' },
      { label: '+58 414-8641818', tel: '+584148641818', note: 'Monagas · José Ponce' },
    ],
    wa: '584148641818',
    waText: 'Hello%2C%20I%27m%20interested%20in%20SuiteHub%20from%20Venezuela',
  },
];
---
<BaseLayout title="Contact · SuiteHub" description="Four countries, one platform. Offices in USA (PROOQ LLC), Panama (PROOQ S.A.), and Spain. Soft launch in Venezuela.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[400px] bg-radial-brand pointer-events-none"></div>
    <div class="wrap relative pt-12 pb-12">
      <div class="text-center max-w-2xl mx-auto">
        <span class="eyebrow">Let's talk</span>
        <h1 class="text-4xl sm:text-5xl font-display font-bold">Ready to meet <span class="text-gradient">SuiteHub</span>?</h1>
        <p class="text-ink-300 mt-5">
          A <strong class="text-white">PROOQ LLC</strong> (USA) product. Local operations in Panama through PROOQ S.A.
          Soft launch in USA, Venezuela, and Spain. WhatsApp is the fastest channel — reply within minutes during business hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick channels -->
  <section class="pb-8">
    <div class="wrap">
      <div class="grid sm:grid-cols-2 gap-5 max-w-3xl mx-auto">
        <a href="https://wa.me/50766326006?text=Hello%2C%20I%27m%20interested%20in%20SuiteHub"
           target="_blank" rel="noopener"
           class="card-glass p-7 text-center hover:border-emerald-500/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/15 text-emerald-400 mx-auto mb-4 flex items-center justify-center text-2xl">
            <i class="fa-brands fa-whatsapp"></i>
          </div>
          <div class="text-lg font-display font-semibold">WhatsApp</div>
          <div class="text-sm text-ink-400 mt-1 mb-3">Immediate conversation</div>
          <div class="text-brand-400 text-sm font-medium">+507 6632-6006 (PA operations)</div>
        </a>

        <a href="mailto:info@suitehub.net"
           class="card-glass p-7 text-center hover:border-brand-500/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 text-brand-400 mx-auto mb-4 flex items-center justify-center text-2xl">
            <i class="fa-solid fa-envelope"></i>
          </div>
          <div class="text-lg font-display font-semibold">Email</div>
          <div class="text-sm text-ink-400 mt-1 mb-3">For formal matters</div>
          <div class="text-brand-400 text-sm font-medium">info@suitehub.net</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Offices by country -->
  <section class="section">
    <div class="wrap">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="eyebrow">Our channels</span>
        <h2 class="text-3xl lg:text-4xl font-display font-bold">
          Four countries, <span class="text-gradient">one team.</span>
        </h2>
        <p class="mt-4 text-ink-300 text-sm">
          We support clients from our offices in USA, Panama, and Spain. Venezuela in soft launch — leads via email/WhatsApp.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
        {offices.map(o => (
          <div class="card-glass p-7">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <div class="text-2xl mb-1">{o.flag}</div>
                <div class="text-lg font-display font-semibold">{o.country}</div>
                <div class="text-xs text-ink-400">{o.role}</div>
              </div>
            </div>

            {o.address && (
              <div class="text-sm text-ink-300 mt-3 flex items-start gap-2">
                <i class="fa-solid fa-location-dot text-brand-400 mt-1"></i>
                <span>{o.address[0]}<br/>{o.address[1]}</span>
              </div>
            )}

            {o.phones.length > 0 && (
              <div class="mt-3 space-y-1.5">
                {o.phones.map(p => (
                  <a href={`tel:${p.tel}`} class="text-sm text-ink-300 hover:text-white flex items-center gap-2">
                    <i class="fa-solid fa-phone text-brand-400 text-xs"></i>
                    <span>{p.label}{p.note && <span class="text-ink-500"> · {p.note}</span>}</span>
                  </a>
                ))}
              </div>
            )}

            <div class="mt-4 pt-4 border-t border-white/5 flex flex-wrap gap-2">
              <a href={`https://wa.me/${o.wa}?text=${o.waText}`} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 hover:bg-emerald-500/20 transition-colors">
                <i class="fa-brands fa-whatsapp"></i> WhatsApp
              </a>
              <a href="mailto:info@suitehub.net"
                 class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300 hover:bg-brand-500/20 transition-colors">
                <i class="fa-solid fa-envelope"></i> info@suitehub.net
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
