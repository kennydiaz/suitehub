---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact · SuiteHub" description="Let's talk about how SuiteHub can help your business.">
  <section class="section">
    <div class="wrap">
      <div class="text-center mb-14 max-w-2xl mx-auto">
        <span class="eyebrow">Let's talk</span>
        <h1 class="text-4xl sm:text-5xl font-display font-bold">Ready to meet <span class="text-gradient">SuiteHub</span>?</h1>
        <p class="text-ink-300 mt-5">The fastest channel is WhatsApp. Distributed in Panama by PROOQ S.A. — reply within minutes during business hours.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-5 max-w-4xl mx-auto">
        <a href="https://wa.me/50766326006?text=Hello%2C%20I%27m%20interested%20in%20SuiteHub"
           target="_blank" rel="noopener"
           class="card-glass p-7 text-center hover:border-emerald-500/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/15 text-emerald-400 mx-auto mb-4 flex items-center justify-center text-2xl">
            <i class="fa-brands fa-whatsapp"></i>
          </div>
          <div class="text-lg font-display font-semibold">WhatsApp</div>
          <div class="text-sm text-ink-400 mt-1 mb-3">Immediate conversation</div>
          <div class="text-brand-400 text-sm font-medium">+507 6632-6006</div>
        </a>

        <a href="mailto:info@suitehub.net"
           class="card-glass p-7 text-center hover:border-brand-500/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-brand-500/15 text-brand-400 mx-auto mb-4 flex items-center justify-center text-2xl">
            <i class="fa-solid fa-envelope"></i>
          </div>
          <div class="text-lg font-display font-semibold">Email</div>
          <div class="text-sm text-ink-400 mt-1 mb-3">For formal matters</div>
          <div class="text-brand-400 text-sm font-medium">info@suitehub.net</div>
        </a>

        <div class="card-glass p-7 text-center">
          <div class="w-12 h-12 rounded-xl bg-amber-500/15 text-amber-400 mx-auto mb-4 flex items-center justify-center text-2xl">
            <i class="fa-solid fa-location-dot"></i>
          </div>
          <div class="text-lg font-display font-semibold">Office</div>
          <div class="text-sm text-ink-400 mt-1 mb-3">Visit us</div>
          <div class="text-ink-200 text-sm">Vía Argentina<br/>Bella Vista, Panama</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
