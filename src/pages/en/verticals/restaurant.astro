---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const wa = (text: string) => `https://wa.me/50766326006?text=${encodeURIComponent(text)}`;
const waInfo = wa("Hi, I'd like info about HUB Restaurant 🍽️");
const waDemo = wa("Hi, I'd like a demo of HUB Restaurant for my restaurant");

const chips = [
  '🪑 Live tables',
  '👨‍🍳 Tickets to kitchen',
  '💵 Charge in seconds',
  '📶 Works offline',
];

// Showcase: real screenshots in browser frames, alternating sides
const shots = [
  {
    img: '/images/products/restaurant/shot-pedido.webp',
    title: 'Take the order in one tap',
    desc: 'Large products by category, with modifiers (sizes, paid extras, removed ingredients) and notes. From order to payment in seconds.',
  },
  {
    img: '/images/products/restaurant/shot-mesas.webp',
    title: 'Control your floor live',
    desc: 'A layout that mirrors your real dining room: free, occupied and check-requested tables at a glance. Per-table orders with rounds, merge and split.',
  },
  {
    img: '/images/products/restaurant/shot-cobro.webp',
    title: 'Charge however your guest wants',
    desc: 'Cash, card, Yappy or split payment, with tip and change calculated instantly. Split the bill by person or by item, painlessly.',
  },
  {
    img: '/images/products/restaurant/shot-cocina.webp',
    title: 'Tickets reach the kitchen on their own',
    desc: 'Each item is routed by station (kitchen, bar, dessert) to its network or USB printer. No shouting, no lost slips: your team just cooks.',
  },
  {
    img: '/images/products/restaurant/shot-reportes.webp',
    title: 'Truly measure your business',
    desc: 'Sales, tax, average ticket and best sellers per shift. Cash close with reconciliation and a printable Z report, exportable to Excel.',
  },
];

// Features (all real)
const features = [
  { icon: 'fa-table-cells-large', name: 'Table management', desc: 'Merge, split and move items; assign guests and split the bill by person or item.' },
  { icon: 'fa-bolt', name: 'Touch ordering', desc: 'Large categories and products with smart modifiers; from order to payment in seconds.' },
  { icon: 'fa-money-bill-wave', name: 'Flexible payment', desc: 'Cash, card, Yappy or split, with tip and change calculated instantly.' },
  { icon: 'fa-fire-burner', name: 'Tickets to kitchen', desc: 'Automatic tickets by station to a network or USB printer, routed by category.' },
  { icon: 'fa-cash-register', name: 'Cash close & reconciliation', desc: 'Open with a float, cash movements and a Z close with a count that flags shortages.' },
  { icon: 'fa-box-open', name: 'Recipe-based inventory', desc: 'Each dish subtracts its ingredients from stock on sale: know your real cost and when to restock.' },
  { icon: 'fa-receipt', name: 'DGI electronic invoicing', desc: 'Receipt with CUFE and DGI QR, connected to your PAC. Ready for Panama.' },
  { icon: 'fa-wifi', name: 'Works offline', desc: 'Everything runs on your local network: signal drops and you keep selling. Installable app (PWA).' },
  { icon: 'fa-tablet-screen-button', name: 'Per-device terminals', desc: 'Configure each tablet or register: which one charges, which only takes orders, which prints and where.' },
];

const benefits = [
  'No fee on every sale (0%)',
  'Unlimited tables, registers and stations on your network',
  'Works offline (installable PWA)',
  'DGI electronic invoicing included',
  'Your data is yours, on your own hardware',
  'Local support · no long contracts',
];

const title = 'HUB Restaurant — Management system for restaurants and bars';
const description = 'The system that takes orders, controls your tables and charges even if the internet drops. Tables, kitchen tickets, cash reconciliation, recipe-based inventory and DGI electronic invoicing. For restaurants, cafés, bars and food trucks in Panama.';
---
<BaseLayout title={title} description={description} ogImage="/images/products/restaurant/web-1280.webp">

  <!-- Breadcrumb JSON-LD -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://suitehub.net/en/" },
      { "@type": "ListItem", "position": 2, "name": "Verticals", "item": "https://suitehub.net/en/verticals" },
      { "@type": "ListItem", "position": 3, "name": "HUB Restaurant", "item": "https://suitehub.net/en/verticals/restaurant" }
    ]
  })} />

  <!-- ░░ HERO ░░ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[460px] bg-radial-brand pointer-events-none"></div>
    <div class="absolute inset-0 bg-grid pointer-events-none"></div>
    <div class="wrap relative pt-10 pb-16 sm:pt-14 text-center">
      <a href="/en/verticals" class="inline-flex items-center gap-2 text-xs text-ink-400 hover:text-white transition-colors mb-8">
        <i class="fa-solid fa-arrow-left"></i> All verticals
      </a>

      <div class="reveal max-w-3xl mx-auto">
        <img src="/images/products/restaurant/badge.svg" alt="HUB Restaurant" class="h-20 w-20 mx-auto mb-6" />
        <span class="eyebrow">Restaurants and bars · SuiteHub family</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-[1.05]">
          HUB <span class="text-gradient">Restaurant</span>
        </h1>
        <p class="mt-6 text-lg text-ink-300 leading-relaxed max-w-2xl mx-auto">
          The system that takes orders, controls your tables and charges —even if the internet drops.
          Built for restaurants, cafés, bars and food trucks.
        </p>

        <div class="mt-8 flex flex-wrap gap-3 justify-center">
          <a href={waInfo} target="_blank" rel="noopener" class="btn bg-emerald-500 text-white hover:bg-emerald-400 shadow-glow-sm">
            <i class="fa-brands fa-whatsapp text-lg"></i> Ask about HUB Restaurant
          </a>
          <a href={waDemo} target="_blank" rel="noopener" class="btn-secondary">
            <i class="fa-solid fa-play"></i> Book a demo
          </a>
        </div>

        <div class="mt-9 flex flex-wrap gap-2.5 justify-center">
          {chips.map(c => (
            <span class="text-sm font-medium card-glass px-4 py-2.5">{c}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ PROBLEM → SOLUTION ░░ -->
  <section class="pb-4">
    <div class="wrap">
      <div class="reveal max-w-2xl mx-auto text-center">
        <p class="text-ink-400">😩 Orders on paper, servers shouting at the kitchen, and a register that never balances?</p>
        <p class="text-2xl sm:text-3xl font-display font-bold my-4 leading-tight">
          Run your floor, your kitchen and your register from <span class="text-gradient">one system</span>
        </p>
        <p class="text-ink-300">
          Tables, tickets, payment and inventory in a single app —no per-sale fees and working
          even when the network goes down. Built in Panama 🇵🇦
        </p>
      </div>
    </div>
  </section>

  <!-- ░░ SHOWCASE ░░ -->
  <section class="section">
    <div class="wrap">
      <h2 class="text-center text-sm uppercase tracking-[0.2em] text-brand-400 font-semibold mb-16">
        Here's how it looks inside
      </h2>

      <div class="space-y-20 lg:space-y-28">
        {shots.map((s, i) => (
          <div class="reveal grid lg:grid-cols-2 gap-8 lg:gap-14 items-center">
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="flex items-center gap-3 text-brand-400 font-display font-bold text-sm tracking-widest mb-4">
                {String(i + 1).padStart(2, '0')}
                <span class="h-px w-12 bg-gradient-to-r from-brand-500 to-transparent"></span>
              </div>
              <h3 class="text-2xl lg:text-3xl font-display font-bold mb-3">{s.title}</h3>
              <p class="text-ink-300 leading-relaxed">{s.desc}</p>
            </div>
            <div class={`show-glow ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <figure class="browser">
                <div class="browser-bar">
                  <span class="browser-dot bg-[#ff5f57]"></span>
                  <span class="browser-dot bg-[#febc2e]"></span>
                  <span class="browser-dot bg-[#28c840]"></span>
                  <span class="browser-url">suitehub.net/restaurant</span>
                </div>
                <img src={s.img} alt={s.title} width="1440" height="900" loading="lazy" decoding="async" class="w-full h-auto" />
              </figure>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ FEATURES ░░ -->
  <section class="section bg-navy-900/30">
    <div class="wrap">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="eyebrow">Everything it includes</span>
        <h2 class="text-3xl lg:text-4xl font-display font-bold">HUB Restaurant features</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {features.map(f => (
          <div class="reveal card-glass p-6 hover:border-white/15 transition-colors">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center text-brand-400 bg-white/5 mb-4">
              <i class={`fa-solid ${f.icon} text-lg`}></i>
            </div>
            <div class="font-display font-semibold mb-1.5">{f.name}</div>
            <div class="text-sm text-ink-400 leading-relaxed">{f.desc}</div>
          </div>
        ))}
      </div>
      <p class="mt-7 text-xs text-ink-500 text-center">
        + All SuiteHub core features, according to the edition you choose.
      </p>
    </div>
  </section>

  <!-- ░░ BENEFITS / LET'S TALK ░░ -->
  <section class="section">
    <div class="wrap">
      <div class="reveal card-glass gradient-border max-w-3xl mx-auto p-8 lg:p-12 text-center">
        <span class="eyebrow">Let's talk</span>
        <h2 class="text-2xl lg:text-3xl font-display font-bold mb-3">
          Built for your restaurant. We set it up to fit you.
        </h2>
        <p class="text-ink-300 mb-8 max-w-xl mx-auto">
          Every business is different. Tell us how you work and we'll set up HUB Restaurant with your
          menu, your tables and the way you charge. No long contracts.
        </p>
        <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3 max-w-xl mx-auto text-left mb-8">
          {benefits.map(b => (
            <li class="flex items-start gap-2.5 text-sm text-ink-200">
              <i class="fa-solid fa-circle-check text-emerald-400 mt-0.5"></i>
              <span>{b}</span>
            </li>
          ))}
        </ul>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={waInfo} target="_blank" rel="noopener" class="btn bg-emerald-500 text-white hover:bg-emerald-400 shadow-glow-sm">
            <i class="fa-brands fa-whatsapp text-lg"></i> Message us on WhatsApp
          </a>
          <a href="mailto:info@suitehub.net?subject=I%20want%20info%20about%20HUB%20Restaurant" class="btn-secondary">
            <i class="fa-solid fa-envelope"></i> info@suitehub.net
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ FINAL CTA ░░ -->
  <section class="relative overflow-hidden border-t border-white/5">
    <div class="absolute inset-x-0 bottom-0 h-[300px] bg-radial-brand pointer-events-none rotate-180"></div>
    <div class="wrap relative py-20 text-center">
      <h2 class="reveal text-3xl lg:text-4xl font-display font-bold mb-4">
        Ready to <span class="text-gradient">order</span>?
      </h2>
      <p class="reveal text-ink-300 mb-8 max-w-xl mx-auto">
        We'll give you a demo with your own menu, no strings attached. See HUB Restaurant working
        before you decide.
      </p>
      <a href={waDemo} target="_blank" rel="noopener" class="reveal btn bg-emerald-500 text-white hover:bg-emerald-400 shadow-glow text-base px-8 py-4">
        <i class="fa-brands fa-whatsapp text-xl"></i> Book your demo
      </a>
    </div>
  </section>

  <style>
    .browser {
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 14px;
      overflow: hidden;
      background: #0B0F1A;
      box-shadow: 0 38px 84px -30px rgba(0, 0, 0, 0.85);
    }
    .browser-bar {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 10px 13px;
      background: #06192E;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .browser-dot { width: 11px; height: 11px; border-radius: 50%; flex: none; }
    .browser-url {
      margin-left: 10px;
      font-size: 11px;
      color: #647088;
      background: #020617;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 6px;
      padding: 5px 12px;
      font-family: ui-monospace, monospace;
    }
    .show-glow { position: relative; }
    .show-glow::before {
      content: '';
      position: absolute;
      inset: -2px;
      z-index: -1;
      border-radius: 16px;
      background: radial-gradient(60% 80% at 50% 0%, rgba(21, 130, 245, 0.35), transparent 70%);
      filter: blur(22px);
    }
    @media (max-width: 640px) { .browser-url { display: none; } }
  </style>

</BaseLayout>
