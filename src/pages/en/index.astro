---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEdiciones } from '../../lib/catalog';

const editions = [
  {
    key:    'lite',
    name:   'Lite Edition',
    tagline:'Get started',
    price:  24,
    color:  'from-sky-500/20 to-sky-500/5',
    border: 'border-sky-500/30',
    accent: 'text-sky-400',
    ideal:  'Small business, 1 location, up to 3 users',
    features: [
      'Customers, products, services',
      'Quotes and electronic invoices',
      'Up to 500 records',
      'Email support',
    ],
  },
  {
    key:    'core',
    name:   'Core Edition',
    tagline:'The essentials',
    price:  48,
    color:  'from-cyan-500/20 to-cyan-500/5',
    border: 'border-cyan-500/30',
    accent: 'text-cyan-400',
    ideal:  '2 locations, 8 users, certified e-invoicing',
    features: [
      'Everything in Lite +',
      'DGI electronic invoicing',
      'AR with multi-invoice receipts',
      'Inventory + movements',
      'Pre-built reports',
    ],
  },
  {
    key:     'pro',
    name:    'Pro Edition',
    tagline: 'Most popular',
    price:   96,
    color:   'from-brand-600/30 to-brand-600/5',
    border:  'border-brand-500/50',
    accent:  'text-brand-300',
    featured: true,
    ideal:   'Up to 5 locations, 20 users, automations',
    features: [
      'Everything in Core +',
      'Multi-branch with consolidation',
      'REST API + 100K calls/month',
      'Scheduled automations',
      'WhatsApp Business integrated',
      'SQL reports + PDF templates',
    ],
  },
  {
    key:    'enterprise',
    name:   'Enterprise Edition',
    tagline:'No limits',
    price:  192,
    color:  'from-amber-500/20 to-amber-500/5',
    border: 'border-amber-500/30',
    accent: 'text-amber-400',
    ideal:  'Unlimited branches, 50 users included',
    features: [
      'Everything in Pro +',
      'AI-powered reports',
      'Full white-label',
      'Unlimited API',
      '24/7 priority support',
      'Dedicated onboarding',
    ],
  },
];

// Prices from the panel's canonical catalog (with local fallback).
const _ed = await getEdiciones();
for (const e of editions) {
  const c = _ed[e.key];
  if (!c) continue;
  e.price = c.precio_mes;
  if ('yearly' in e) e.yearly = c.precio_anio;
  if ('priceYearly' in e) e.priceYearly = c.precio_anio;
}

const verticals = [
  { key: 'taller',     name: 'HUB Workshop',    desc: 'Auto repair shops',         icon: 'fa-screwdriver-wrench' },
  { key: 'carwash',    name: 'HUB Carwash',     desc: 'Car washes and detailing',  icon: 'fa-spray-can-sparkles' },
  { key: 'restaurant', name: 'HUB Restaurant',  desc: 'Restaurants and bars',      icon: 'fa-utensils' },
  { key: 'pos',        name: 'HUB POS',         desc: 'Checkout terminal for food service', icon: 'fa-cash-register' },
  { key: 'pet',        name: 'HUB Pet',         desc: 'Vets and pet shops',        icon: 'fa-paw' },
  { key: 'lavanderia', name: 'HUB Laundry',     desc: 'Professional laundries',    icon: 'fa-soap' },
  { key: 'beauty',     name: 'HUB Beauty',      desc: 'Beauty salons, spas',       icon: 'fa-spa' },
  { key: 'clinic',     name: 'HUB Clinic',      desc: 'Practices and clinics',     icon: 'fa-stethoscope' },
  { key: 'gym',        name: 'HUB Gym',         desc: 'Gyms and crossfits',        icon: 'fa-dumbbell' },
  { key: 'inmobiliaria', name: 'HUB Real Estate', desc: 'Real estate agencies',    icon: 'fa-building' },
  { key: 'hotel',      name: 'HUB Hotel',       desc: 'Boutique hotels',           icon: 'fa-hotel' },
  { key: 'phone',      name: 'HUB Phone',       desc: 'Phone repair shops',        icon: 'fa-mobile-screen' },
  { key: 'traffic',    name: 'HUB Traffic',     desc: 'Footfall and heatmaps',     icon: 'fa-people-arrows' },
];

const pacs = [
  {
    name: 'Digifact',
    desc: 'DGI-certified PAC with a modern API',
    icon: 'fa-bolt',
    color: 'text-brand-400',
  },
  {
    name: 'The Factory HKA',
    desc: 'Regional leader in electronic invoicing',
    icon: 'fa-industry',
    color: 'text-sky-400',
  },
  {
    name: 'Factura Fácil',
    desc: 'Panamanian PAC focused on simplicity',
    icon: 'fa-receipt',
    color: 'text-emerald-400',
  },
  {
    name: 'eFacturapty',
    desc: 'DGI-certified Panamanian PAC',
    icon: 'fa-file-invoice',
    color: 'text-amber-400',
  },
];

const testimonials = [
  {
    quote: 'We switched from a legacy system to the Pro Edition and within a week we were issuing electronic invoices with zero DGI rejections. The difference is huge.',
    author: 'Raúl Romero',
    role:   'Lead Technician — QS Express',
    initial: 'R',
    logo:    '/images/tallerqsexpress.png',
  },
];

const stats = [
  { num: '24',   label: 'Active SMBs (Panama)' },
  { num: '5',    label: 'Target countries (PA · US · VE · ES · CO)' },
  { num: '13',   label: 'Specialized verticals' },
  { num: '<24h', label: 'Support response time' },
];

const tour = [
  { label: 'Tables',   icon: 'fa-chair',         img: '/images/products/restaurant/shot-mesas.webp',    alt: 'SuiteHub — real-time dining room table map' },
  { label: 'Order',    icon: 'fa-utensils',      img: '/images/products/restaurant/shot-pedido.webp',   alt: 'SuiteHub — order taking by table' },
  { label: 'Kitchen',  icon: 'fa-fire-burner',   img: '/images/products/restaurant/shot-cocina.webp',   alt: 'SuiteHub — kitchen display screen (KDS)' },
  { label: 'Checkout', icon: 'fa-cash-register', img: '/images/products/restaurant/shot-cobro.webp',    alt: 'SuiteHub — checkout and electronic invoicing' },
  { label: 'Reports',  icon: 'fa-chart-line',    img: '/images/products/restaurant/shot-reportes.webp', alt: 'SuiteHub — sales and operations reports' },
];
---
<BaseLayout
  title="SuiteHub — The multi-country business suite that actually scales"
  description="A PROOQ LLC (USA) product. Multi-jurisdiction electronic invoicing (DGI Panama live; SENIAT Venezuela, Facturae Spain, DIAN Colombia and US state-level on 2026 roadmap), multi-branch, automations, API. Available in Spanish and English. From $24/month.">

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="aurora" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-grid pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-x-0 top-0 h-[600px] bg-radial-brand pointer-events-none" aria-hidden="true"></div>

    <div class="wrap relative section">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-fade-up">
          <span class="eyebrow">
            <i class="fa-solid fa-bolt mr-1"></i> Multi-country business suite · PA · US · VE · ES · CO
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-[1.05] tracking-tight">
            A business suite<br/>
            <span class="text-gradient">that actually scales</span><br/>
            with you.
          </h1>
          <p class="mt-6 text-lg text-ink-300 max-w-xl leading-relaxed">
            Management platform for SMBs across <strong class="text-white">Panama, USA, Venezuela, Spain, and Colombia</strong>.
            Multi-jurisdiction electronic invoicing, multi-branch, automations and REST API.
            <span class="text-brand-300">From $24/month.</span>
          </p>

          <div class="mt-5 inline-flex items-center gap-2 text-xs px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300">
            <i class="fa-solid fa-globe"></i>
            Available in <strong class="text-white">English</strong> and <strong class="text-white">Spanish</strong>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="https://wa.me/50766326006?text=Hello%2C%20I%27d%20like%20a%20demo"
               target="_blank" rel="noopener" class="btn-primary text-base">
              <i class="fa-brands fa-whatsapp text-xl"></i>
              Talk to sales now
            </a>
            <a href="#tiers" class="btn-secondary text-base">
              See editions and pricing
              <i class="fa-solid fa-arrow-down text-xs ml-1"></i>
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-6 text-sm text-ink-400">
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-shield-halved text-emerald-400"></i>
              Multi-jurisdiction e-invoicing
            </div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-clock text-brand-400"></i>
              Setup in 24h
            </div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-headset text-brand-400"></i>
              EN / ES support
            </div>
          </div>
        </div>

        <!-- Visual: real product in a browser mockup -->
        <div class="relative animate-fade-in" style="perspective:1200px;">
          <!-- Glow orb -->
          <div class="absolute -inset-10 bg-brand-600/20 rounded-full blur-3xl" aria-hidden="true"></div>

          <div id="hero-tilt" class="tilt relative browser-mock">
            <div class="browser-bar">
              <span class="bg-rose-400/70"></span>
              <span class="bg-amber-400/70"></span>
              <span class="bg-emerald-400/70"></span>
              <span class="ml-3 text-[10px] text-ink-500 truncate">app.suitehub.net · Dashboard</span>
            </div>
            <img src="/images/hubcore2.webp" alt="SuiteHub dashboard — business management panel"
                 width="1885" height="931" fetchpriority="high"
                 class="w-full block" />
          </div>

          <!-- Floating pill: e-invoicing -->
          <div class="absolute -top-4 -right-2 sm:-right-5 card-glass px-3.5 py-2 flex items-center gap-2 shadow-2xl">
            <i class="fa-solid fa-receipt text-emerald-400"></i>
            <span class="text-xs font-medium">Electronic invoice with CUFE</span>
          </div>

          <!-- Floating pill: live -->
          <div class="absolute -bottom-5 left-3 sm:-left-5 card-glass px-4 py-2.5 flex items-center gap-3 shadow-2xl">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-xs font-medium">24 businesses invoicing today</span>
          </div>
        </div>
      </div>

      <div class="reveal mt-20 lg:mt-28 grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/5">
        {stats.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1} bg-navy-950 p-6 lg:p-8 text-center`}>
            <div class="text-3xl lg:text-4xl font-display font-bold text-white tabular-nums" data-countup={s.num}>{s.num}</div>
            <div class="text-xs uppercase tracking-wider text-ink-400 mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRODUCT TOUR (tabs) -->
  <section class="section">
    <div class="wrap">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="eyebrow">A look inside</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          This is <span class="text-gradient">SuiteHub in action.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          From the dining room to the kitchen, from checkout to reports — walk through a real HUB Restaurant flow.
          Every vertical looks and feels built for your business.
        </p>
      </div>

      <div class="reveal max-w-5xl mx-auto" data-tour>
        <!-- Tabs -->
        <div class="flex flex-wrap justify-center gap-2 mb-6" role="tablist" aria-label="SuiteHub tour">
          {tour.map((t, i) => (
            <button type="button" role="tab" data-tour-tab={i} aria-selected={i === 0 ? 'true' : 'false'} class="tour-tab">
              <i class={`fa-solid ${t.icon}`}></i> {t.label}
            </button>
          ))}
        </div>

        <!-- Panels -->
        <div class="browser-mock relative">
          <div class="browser-bar">
            <span class="bg-rose-400/70"></span>
            <span class="bg-amber-400/70"></span>
            <span class="bg-emerald-400/70"></span>
            <span class="ml-3 text-[10px] text-ink-500 truncate">app.suitehub.net · HUB Restaurant</span>
          </div>
          {tour.map((t, i) => (
            <img src={t.img} alt={t.alt} width="1440" height="900" loading="lazy"
                 data-tour-panel={i} class={`w-full block ${i === 0 ? '' : 'hidden'}`} />
          ))}
        </div>

        <p class="text-center mt-6 text-sm text-ink-400">
          Want to see it with your own data?
          <a href="https://wa.me/50766326006?text=Hello%2C%20I%27d%20like%20a%20SuiteHub%20demo" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 font-medium">Book a live demo</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- PACs -->
  <section class="py-16 sm:py-20 bg-navy-900/30 border-y border-white/5">
    <div class="wrap">
      <div class="text-center mb-10">
        <span class="eyebrow">Multi-jurisdiction electronic invoicing</span>
        <h2 class="text-2xl sm:text-3xl font-display font-bold">
          Today <span class="text-gradient">4 DGI Panama PACs</span> in production · 2026 roadmap: SENIAT VE, Facturae ES, DIAN CO, US state-level
        </h2>
        <p class="mt-3 text-sm text-ink-400 max-w-xl mx-auto">
          You pick the PAC you want to work with. SuiteHub connects directly and handles the entire XML, CUFE and QR flow so you never have to think about regulation. Adapter layer designed to abstract any jurisdiction.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
        {pacs.map((p, i) => (
          <div class={`reveal reveal-delay-${i + 1} lift card-glass p-6 text-center hover:border-brand-500/30 transition-colors`}>
            <div class={`w-12 h-12 mx-auto rounded-xl bg-white/5 flex items-center justify-center text-2xl mb-3 ${p.color}`}>
              <i class={`fa-solid ${p.icon}`}></i>
            </div>
            <div class="font-display font-semibold text-base">{p.name}</div>
            <p class="text-xs text-ink-400 mt-1.5">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EDITIONS -->
  <section id="tiers" class="section relative">
    <div class="wrap">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow">The SuiteHub family</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          Four editions. <span class="text-gradient">Grow without migrating.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          Start with the basics today and upgrade your edition when you need to — no data migration,
          no relearning, no downtime. Same core, more horsepower.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {editions.map((t, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative rounded-2xl border ${t.border} bg-gradient-to-b ${t.color} p-6 ${t.featured ? 'lg:scale-105 lg:-mt-2 shadow-glow' : 'lift'}`}>
            {t.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-brand-600 text-white text-[10px] font-semibold uppercase tracking-wider rounded-full">
                Most popular
              </span>
            )}
            <div class={`text-xs uppercase tracking-wider ${t.accent} font-semibold mb-2`}>{t.tagline}</div>
            <h3 class="text-2xl font-display font-bold mb-1">{t.name}</h3>
            <p class="text-xs text-ink-400 mb-5 min-h-[36px]">{t.ideal}</p>
            <div class="mb-6">
              <span class="text-4xl font-display font-bold">${t.price}</span>
              <span class="text-sm text-ink-400">/mo</span>
            </div>
            <ul class="space-y-2.5 mb-7 text-sm">
              {t.features.map(f => (
                <li class="flex items-start gap-2">
                  <i class={`fa-solid fa-check ${t.accent} mt-1 text-xs`}></i>
                  <span class="text-ink-200">{f}</span>
                </li>
              ))}
            </ul>
            <a href={`/en/products#${t.key}`}
               class={`block w-full text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${t.featured ? 'bg-brand-600 hover:bg-brand-500 text-white' : 'bg-white/5 hover:bg-white/10 text-white border border-white/10'}`}>
              See details
            </a>
          </div>
        ))}
      </div>

      <p class="text-center mt-10 text-sm text-ink-400">
        16% off when paid annually · Free setup · No long-term contracts
      </p>
    </div>
  </section>

  <!-- VERTICALS -->
  <section id="verticals" class="section bg-navy-900/50 relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-600/10 rounded-full blur-3xl"></div>

    <div class="wrap relative">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow">Specialized verticals</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          SuiteHub spoken <span class="text-gradient">in your language.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          Every industry has its own jargon, flow and needs.
          We take SuiteHub and tune it for your specific business — ready to use from day one.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {verticals.map((v, i) => (
          <a href={`/en/verticals#${v.key}`}
             class={`reveal reveal-delay-${(i % 4) + 1} group lift card-glass p-5 hover:border-brand-500/30 hover:bg-white/[0.05] transition-all`}>
            <img src={`/images/products/${v.key}/badge.svg`} alt={v.name} class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" loading="lazy" />
            <h3 class="text-base font-display font-semibold mb-1">{v.name}</h3>
            <p class="text-xs text-ink-400">{v.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/en/verticals" class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 text-sm font-medium">
          Explore all verticals <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- CASE STUDY -->
  <section class="section">
    <div class="wrap">
      <div class="card-glass overflow-hidden grid lg:grid-cols-5 gap-0">
        <div class="lg:col-span-3 p-10 lg:p-14 flex flex-col justify-center">
          <span class="eyebrow">
            <i class="fa-solid fa-star mr-1"></i> Case study
          </span>
          <h2 class="text-3xl lg:text-4xl font-display font-bold mb-5">
            QS Express tripled their <span class="text-gradient">operational capacity</span>
          </h2>
          <p class="text-ink-300 leading-relaxed mb-8">
            An auto-repair shop in La Chorrera with 20+ years of experience migrated from
            Excel and notebooks. In 4 weeks they were already issuing electronic invoices,
            booking appointments online and tracking every work order in real time.
          </p>

          <div class="grid grid-cols-3 gap-6 mb-8">
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">3×</div>
              <div class="text-xs text-ink-400 mt-1">More orders/day</div>
            </div>
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">0</div>
              <div class="text-xs text-ink-400 mt-1">DGI rejections</div>
            </div>
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">4 wks</div>
              <div class="text-xs text-ink-400 mt-1">To full speed</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="/en/cases#qs-express" class="btn-secondary">
              Read the full case <i class="fa-solid fa-arrow-right text-xs"></i>
            </a>
            <a href="https://tallerqsexpress.com" target="_blank" rel="noopener"
               class="btn-ghost text-sm">
              Visit tallerqsexpress.com <i class="fa-solid fa-external-link text-xs"></i>
            </a>
          </div>
        </div>

        <div class="lg:col-span-2 bg-gradient-to-br from-navy-800 to-navy-900 p-10 flex items-center justify-center border-t lg:border-t-0 lg:border-l border-white/5">
          <div class="text-center">
            <img src="/images/tallerqsexpress.png" alt="QS Express" width="300" height="271"
                 class="w-32 mx-auto mb-4 rounded-xl bg-white/5 p-3" />
            <div class="flex items-center justify-center gap-2.5 mb-4">
              <img src="/images/products/taller/badge.svg" alt="HUB Workshop" class="w-12 h-12" />
              <span class="font-display font-bold text-xl">HUB Workshop</span>
            </div>
            <div class="text-sm text-ink-400">Auto-repair shop — La Chorrera</div>
            <div class="mt-4 inline-flex items-center gap-2 text-xs text-emerald-400 bg-emerald-400/10 px-3 py-1.5 rounded-full">
              <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
              Active since 2026
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section bg-navy-900/30">
    <div class="wrap">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow">What clients say</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          Built <span class="text-gradient">alongside the people who use it.</span>
        </h2>
      </div>

      <div class="max-w-2xl mx-auto">
        {testimonials.map((t, i) => (
          <figure class={`reveal reveal-delay-${i + 1} card-glass p-7 flex flex-col`}>
            <div class="text-brand-400 text-2xl mb-4">
              <i class="fa-solid fa-quote-left"></i>
            </div>
            <blockquote class="text-ink-200 leading-relaxed flex-1 italic">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-6 pt-6 border-t border-white/5 flex items-center gap-3">
              {t.logo ? (
                <img src={t.logo} alt={t.author} class="w-10 h-10 rounded-full bg-white/10 object-contain p-1" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white font-bold text-sm">
                  {t.initial}
                </div>
              )}
              <div>
                <div class="text-sm font-medium text-white">{t.author}</div>
                <div class="text-xs text-ink-400">{t.role}</div>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section relative overflow-hidden">
    <div class="absolute inset-0 bg-radial-brand pointer-events-none"></div>

