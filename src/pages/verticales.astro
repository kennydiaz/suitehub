---
import BaseLayout from '../layouts/BaseLayout.astro';

const verticales = [
  {
    key:    'taller',
    name:   'HUB Taller',
    icon:   'fa-screwdriver-wrench',
    screenshot: '/images/products/taller/qs-express-reportes-1024.webp',
    screenshotH: 754,
    sector: 'Talleres mecánicos',
    short:  'Para talleres mecánicos, autoservicios y centros de diagnóstico.',
    pitch:  'Recepción rápida del vehículo, órdenes de trabajo con servicios y repuestos, agenda online para citas, vehículo + cliente vinculados, facturación electrónica directa.',
    features: [
      { icon: 'fa-bolt',           name: 'Recepción rápida',     desc: 'Capturas placa, cliente y queja en 30 segundos' },
      { icon: 'fa-clipboard-list', name: 'Órdenes de trabajo',   desc: 'Servicios + repuestos + tiempo + estado' },
      { icon: 'fa-calendar-days',  name: 'Agenda de citas online', desc: 'Cliente reserva por la web, tú confirmas' },
      { icon: 'fa-car',            name: 'Histórico de vehículos', desc: 'Servicios pasados, kilometraje, próximas revisiones' },
      { icon: 'fa-tools',          name: 'Catálogo de servicios', desc: 'Precios, duración, técnicos asignables' },
      { icon: 'fa-receipt',        name: 'Facturación electrónica', desc: 'DGI Panamá con CUFE y QR · roadmap multi-país 2026' },
    ],
    cliente: 'QS Express — Taller mecánico en La Chorrera',
  },
  {
    key:    'carwash',
    name:   'HUB Carwash',
    icon:   'fa-spray-can-sparkles',
    screenshot: '/images/products/carwash/hub-carwash-dashboard.webp',
    screenshotH: 1009,
    sector: 'Autolavados y car wash',
    short:  'Para autolavados, car wash express, detailing y lavado a domicilio.',
    pitch:  'Recepción por placa, paquetes de lavado con precio y duración, bahías y lavadores asignables con cola en vivo, membresías de lavados ilimitados, aviso al cliente cuando el auto está listo y facturación electrónica directa.',
    features: [
      { icon: 'fa-bolt',           name: 'Recepción por placa',  desc: 'Placa, tipo de vehículo y paquete en segundos' },
      { icon: 'fa-layer-group',    name: 'Paquetes de lavado',   desc: 'Básico, premium, encerado, detailing con precio y duración' },
      { icon: 'fa-warehouse',      name: 'Bahías y lavadores',   desc: 'Asignas bahía y personal, ves la cola de vehículos en vivo' },
      { icon: 'fa-infinity',       name: 'Membresía de lavados', desc: 'Plan mensual de lavados ilimitados con cobro recurrente' },
      { icon: 'fa-mobile-screen',  name: 'Aviso cuando está listo', desc: 'WhatsApp automático al cliente al terminar el servicio' },
      { icon: 'fa-receipt',        name: 'Facturación electrónica', desc: 'DGI Panamá con CUFE y QR · roadmap multi-país 2026' },
    ],
  },
  {
    key:    'restaurant',
    name:   'HUB Restaurant',
    landing: '/verticales/restaurant',
    icon:   'fa-utensils',
    screenshot: '/images/products/restaurant/web-1280.webp',
    screenshotH: 875,
    sector: 'Restaurantes y bares',
    short:  'Para restaurantes, cafeterías, bares y food trucks.',
    pitch:  'Mesas con estado en vivo, comandas que llegan a cocina y barra, KDS, división de cuentas, propinas, integración con domicilio, reportes por turno.',
    features: [
      { icon: 'fa-table',          name: 'Mesas en vivo',        desc: 'Plano del salón, libre/ocupada/cuenta pedida' },
      { icon: 'fa-fire',           name: 'Comanda a cocina (KDS)', desc: 'Orden separada por estación: cocina, bar, postre' },
      { icon: 'fa-users-rectangle', name: 'Dividir cuentas',      desc: 'Por persona, por producto, mixto' },
      { icon: 'fa-percent',        name: 'Propinas y descuentos', desc: 'Configurables por mesa o ticket' },
      { icon: 'fa-motorcycle',     name: 'Domicilio',             desc: 'Pedidos por WhatsApp/web → cocina directo' },
      { icon: 'fa-chart-line',     name: 'Reportes por turno',    desc: 'Cierre de caja, top platos, mesero del día' },
    ],
  },
  {
    key:    'pos',
    name:   'HUB POS',
    icon:   'fa-cash-register',
    screenshot: '/images/products/pos/web-1280.webp',
    screenshotH: 996,
    sector: 'Punto de venta · caja',
    short:  'Para food trucks, quick-service, cafeterías y barras: cobra rápido, con o sin internet.',
    pitch:  'La caja en sí. Toma el pedido por mesa o para llevar, aplica modificadores, lo envía a cocina, genera la pre-cuenta y cobra con cualquier método. Cierre de caja con arqueo. Instalable como app y funciona en local sin depender de internet.',
    features: [
      { icon: 'fa-bolt',            name: 'Tomar pedido rápido',  desc: 'Por mesa o para llevar, productos por categoría en segundos' },
      { icon: 'fa-pen',             name: 'Modificadores y notas', desc: 'Término, extras con precio, notas por ítem' },
      { icon: 'fa-money-bill-wave', name: 'Pre-cuenta y cobro',   desc: 'Multi-método (efectivo, tarjeta, Yappy, mixto), vuelto automático' },
      { icon: 'fa-cash-register',   name: 'Cierre de caja',       desc: 'Arqueo por turno, diferencias auditadas' },
      { icon: 'fa-wifi',            name: 'Funciona offline',     desc: 'PWA instalable; sigue cobrando sin internet y sincroniza luego' },
      { icon: 'fa-qrcode',          name: 'Ticket con QR de FE',  desc: 'Recibo configurable con CUFE y QR de la DGI' },
    ],
  },
  {
    key:    'pet',
    name:   'HUB Pet',
    icon:   'fa-paw',
    screenshot: '/images/products/pet/web-1280.webp',
    screenshotH: 994,
    sector: 'Veterinarias y pet shops',
    short:  'Para clínicas veterinarias, peluquerías caninas y pet shops.',
    pitch:  'Ficha médica digital por mascota, recordatorios automáticos de vacunas y desparasitación, agenda con dueño + mascota, productos veterinarios con receta.',
    features: [
      { icon: 'fa-file-medical',   name: 'Ficha médica digital', desc: 'Historial completo, vacunas, alergias, peso' },
      { icon: 'fa-bell',           name: 'Recordatorios automáticos', desc: 'Vacuna próxima, desparasitación, control' },
      { icon: 'fa-calendar-check', name: 'Agenda dueño + mascota', desc: 'Veterinaria, peluquería, hospitalización' },
      { icon: 'fa-prescription',   name: 'Recetas con stock',    desc: 'Medicamento + control de venta regulada' },
      { icon: 'fa-camera',         name: 'Galería por mascota',  desc: 'Fotos antes/después, radiografías' },
    ],
  },
  {
    key:    'beauty',
    name:   'HUB Beauty',
    icon:   'fa-spa',
    screenshot: '/images/products/beauty/hub-beauty-dashboard.webp',
    screenshotH: 940,
    sector: 'Salones de belleza, spas, barberías',
    short:  'Para salones, spas, barberías y centros estéticos.',
    pitch:  'Reserva online por servicio y profesional, comisiones por estilista, productos de venta + servicios, recordatorios SMS/WhatsApp.',
    features: [
      { icon: 'fa-calendar-day',   name: 'Reserva online',       desc: 'Cliente elige servicio, hora y profesional' },
      { icon: 'fa-percent',        name: 'Comisiones por estilista', desc: 'Cálculo automático por servicio o producto' },
      { icon: 'fa-shopping-bag',   name: 'Productos + servicios', desc: 'Venta combinada en un solo ticket' },
      { icon: 'fa-bell',           name: 'Recordatorios WA',     desc: '24h antes confirmas asistencia' },
    ],
  },
  {
    key:    'clinic',
    name:   'HUB Clinic',
    icon:   'fa-stethoscope',
    screenshot: '/images/products/clinic/hub-clinic-dashboard.webp',
    screenshotH: 940,
    sector: 'Consultorios y clínicas',
    short:  'Para consultorios médicos, odontológicos y clínicas multi-especialidad.',
    pitch:  'Expediente clínico digital, agenda por médico, recetas electrónicas, historial de pacientes, facturación a aseguradoras.',
    features: [
      { icon: 'fa-notes-medical',  name: 'Expediente digital',   desc: 'SOAP, antecedentes, signos vitales' },
      { icon: 'fa-calendar-days',  name: 'Agenda multi-médico',  desc: 'Por especialista, sala, equipo' },
      { icon: 'fa-prescription-bottle-medical', name: 'Recetas digitales', desc: 'PDF firmado o impreso, control regulado' },
      { icon: 'fa-shield-heart',   name: 'Seguros médicos',      desc: 'Facturación a aseguradoras con códigos' },
    ],
  },
  {
    key:    'gym',
    name:   'HUB Gym',
    icon:   'fa-dumbbell',
    screenshot: '/images/products/gym/hub-gym-dashboard.webp',
    screenshotH: 940,
    sector: 'Gimnasios, crossfit, yoga',
    short:  'Para gimnasios, boxes de crossfit, estudios de yoga y centros deportivos.',
    pitch:  'Membresías mensuales/anuales, control de acceso por QR, clases con cupo limitado, entrenadores asignables, retención por inasistencia.',
    features: [
      { icon: 'fa-id-card',        name: 'Membresías',           desc: 'Cobro recurrente, congelar, suspender' },
      { icon: 'fa-qrcode',         name: 'Control de acceso',    desc: 'Cliente entra escaneando QR de su app' },
      { icon: 'fa-people-group',   name: 'Clases con cupo',      desc: 'Reserva online, lista de espera' },
      { icon: 'fa-chart-line',     name: 'Retención',            desc: 'Alerta si un miembro deja de venir 14 días' },
    ],
  },
  {
    key:    'lavanderia',
    name:   'HUB Lavandería',
    icon:   'fa-soap',
    screenshot: '/images/products/lavanderia/hub-lavanderia-dashboard.webp',
    screenshotH: 940,
    sector: 'Lavanderías profesionales',
    short:  'Para lavanderías, tintorerías y servicios de planchado.',
    pitch:  'Boleta con código de retiro, etapa del proceso (lavado/secado/planchado), precio por kilo o por prenda, recordatorio cuando está listo.',
    features: [
      { icon: 'fa-receipt',        name: 'Boleta con código',    desc: 'Cliente retira con su código único' },
      { icon: 'fa-spinner',        name: 'Etapas del proceso',   desc: 'Recibido → lavado → secado → listo' },
      { icon: 'fa-weight-hanging', name: 'Precio por kilo o prenda', desc: 'Configurable por servicio' },
      { icon: 'fa-mobile-screen',  name: 'Aviso WhatsApp',       desc: 'Auto-mensaje cuando está listo' },
    ],
  },
  {
    key:    'inmobiliaria',
    name:   'HUB Inmobiliaria',
    icon:   'fa-building',
    screenshot: '/images/products/inmobiliaria/hub-inmobiliaria-dashboard.webp',
    screenshotH: 940,
    sector: 'Bienes raíces',
    short:  'Para corredoras inmobiliarias y desarrolladoras pequeñas.',
    pitch:  'Cartera de propiedades, leads con etapa del pipeline, contratos de alquiler con cobro recurrente, agentes con comisiones.',
    features: [
      { icon: 'fa-house',          name: 'Catálogo de propiedades', desc: 'Fotos, video, precio, estado' },
      { icon: 'fa-funnel-dollar',  name: 'Pipeline de leads',    desc: 'Interesado → visita → oferta → cierre' },
      { icon: 'fa-file-contract',  name: 'Contratos de alquiler', desc: 'Cobro mensual auto, garantías' },
      { icon: 'fa-handshake',      name: 'Comisiones agentes',   desc: 'Por venta cerrada o renta gestionada' },
    ],
  },
  {
    key:    'hotel',
    name:   'HUB Hotel',
    icon:   'fa-hotel',
    screenshot: '/images/products/hotel/web-1200.webp',
    screenshotH: 922,
    sector: 'Hoteles boutique y hostales',
    short:  'Para hoteles boutique, hostales, glampings y B&B.',
    pitch:  'Calendario de habitaciones, reservas por canal (Booking/Airbnb/directo), check-in/out con factura, consumo de minibar, housekeeping.',
    features: [
      { icon: 'fa-calendar',       name: 'Tape chart',           desc: 'Vista calendario de ocupación por habitación' },
      { icon: 'fa-bell-concierge', name: 'Check-in / out',       desc: 'Pasaporte, firma digital, factura inmediata' },
      { icon: 'fa-bed',            name: 'Housekeeping',         desc: 'Estado de habitación: limpia/sucia/inspección' },
      { icon: 'fa-link',           name: 'Channel manager',      desc: 'Sync con Booking, Airbnb, Expedia (Pro+)' },
    ],
  },
  {
    key:    'phone',
    name:   'HUB Phone',
    icon:   'fa-mobile-screen',
    screenshot: '/images/products/phone/hub-phone-dashboard.webp',
    screenshotH: 940,
    sector: 'Reparación de celulares',
    short:  'Para tiendas de reparación de celulares, tablets y laptops.',
    pitch:  'Recepción del equipo con diagnóstico, cotización por daño, repuestos vinculados a la orden, garantía digital, ticket con código.',
    features: [
      { icon: 'fa-magnifying-glass', name: 'Diagnóstico inicial', desc: 'Modelo, daño visible, contraseña, accesorios' },
      { icon: 'fa-money-bill-trend-up', name: 'Cotización al cliente', desc: 'Apruebas y avanzamos / no apruebas y devolvemos' },
      { icon: 'fa-microchip',      name: 'Repuestos vinculados',  desc: 'Stock que descuenta al instalar' },
      { icon: 'fa-shield',         name: 'Garantía digital',      desc: 'PDF con QR para reclamo posterior' },
    ],
  },
  {
    key:    'traffic',
    name:   'HUB Traffic',
    icon:   'fa-people-arrows',
    screenshot: '/images/products/traffic/hub-traffic-dashboard.webp',
    screenshotH: 940,
    sector: 'Analítica de afluencia y conducta en tienda',
    short:  'Para tiendas, centros comerciales, locales retail y espacios de alto tráfico.',
    pitch:  'Conteo automático de personas, mapas de calor por zona, tiempo de permanencia, conversión visita-venta cruzada con tu POS, comparativas por hora/día y alertas de aforo en tiempo real.',
    features: [
      { icon: 'fa-people-line',     name: 'Conteo de afluencia',  desc: 'Entradas y salidas en tiempo real con sensor o cámara' },
      { icon: 'fa-fire',            name: 'Mapas de calor',        desc: 'Zonas calientes y frías por hora, día, semana' },
      { icon: 'fa-stopwatch',       name: 'Dwell time',            desc: 'Tiempo promedio que la gente pasa en cada zona' },
      { icon: 'fa-arrow-trend-up',  name: 'Conversión visita→venta', desc: 'Cruce con HUB POS para medir tasa de cierre real' },
      { icon: 'fa-chart-column',    name: 'Comparativas',          desc: 'Hora pico, día más fuerte, picos vs. promedio' },
      { icon: 'fa-bell',            name: 'Alertas de aforo',      desc: 'Aviso cuando se supera el límite de personas' },
    ],
  },
];
---
<BaseLayout title="Verticales · SuiteHub" description="13 verticales especializados de SuiteHub: HUB Taller, Carwash, Restaurant, POS, Pet, Beauty, Clinic, Gym, Lavandería, Inmobiliaria, Hotel, Phone y Traffic.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-[400px] bg-radial-brand pointer-events-none"></div>
    <div class="wrap relative pt-12 pb-16">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow">13 verticales especializados</span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-[1.05]">
          SuiteHub <span class="text-gradient">para tu industria</span>, no genérico.
        </h1>
        <p class="mt-6 text-lg text-ink-300 leading-relaxed">
          Cada vertical hereda el núcleo SuiteHub y le sumamos los flujos, la jerga y las pantallas
          que tu industria necesita. Sin pagar por funciones de otra industria que no usas.
        </p>
      </div>
    </div>
  </section>

  <!-- Index de verticales -->
  <section class="pb-12">
    <div class="wrap">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
        {verticales.map(v => (
          <a href={v.landing ?? `#${v.key}`} class="group card-glass p-4 text-center hover:border-brand-500/30 transition-colors relative">
            {v.landing && (
              <span class="absolute top-2 right-2 text-[9px] uppercase tracking-wider font-bold text-emerald-400 bg-emerald-400/10 border border-emerald-400/30 rounded-full px-2 py-0.5">Ver más</span>
            )}
            <img src={`/images/products/${v.key}/badge.svg`} alt={v.name} class="w-10 h-10 mx-auto mb-2 group-hover:scale-110 transition-transform" loading="lazy" />
            <div class="text-xs font-display font-semibold">{v.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cada vertical en detalle -->
  {verticales.map((v, i) => (
    <section id={v.key} class={`section ${i % 2 === 1 ? 'bg-navy-900/30' : ''}`}>
      <div class="wrap">
        <div class="grid lg:grid-cols-12 gap-10 lg:gap-14">
          <!-- Header -->
          <div class="lg:col-span-5 lg:sticky lg:top-28 self-start">
            <img src={`/images/products/${v.key}/badge.svg`} alt={v.name} class="h-20 w-20 mb-6" />
            <div class="text-xs uppercase tracking-wider text-brand-400 font-semibold mb-2">{v.sector}</div>
            <h2 class="text-3xl lg:text-4xl font-display font-bold mb-4">{v.name}</h2>
            <p class="text-base text-ink-300 leading-relaxed mb-6">{v.pitch}</p>

            {v.cliente && (
              <div class="card-glass p-4 mb-6">
                <div class="text-xs uppercase tracking-wider text-emerald-400 font-semibold mb-1">
                  <i class="fa-solid fa-circle-check"></i> En producción
                </div>
                <div class="text-sm text-ink-200">{v.cliente}</div>
              </div>
            )}

            <div class="flex flex-wrap gap-3">
              {v.landing && (
                <a href={v.landing} class="btn-primary">
                  <i class="fa-solid fa-arrow-right"></i>
                  Ver todo sobre {v.name}
                </a>
              )}
              <a href={`https://wa.me/50766326006?text=Hola%2C%20quiero%20info%20de%20${encodeURIComponent(v.name)}`}
                 target="_blank" rel="noopener" class={v.landing ? 'btn-secondary' : 'btn-primary'}>
                <i class="fa-brands fa-whatsapp"></i>
                Pregunta por {v.name}
              </a>
            </div>
          </div>

          <!-- Features grid -->
          <div class="lg:col-span-7">
            {v.screenshot && (
              <figure class="mb-8 rounded-xl overflow-hidden border border-white/10 shadow-glow-sm bg-navy-950">
                <img src={v.screenshot} alt={`Captura de pantalla de ${v.name}`} width="1280" height={v.screenshotH} loading="lazy" decoding="async" class="w-full h-auto" />
              </figure>
            )}
            <h3 class="text-xs uppercase tracking-[0.2em] text-brand-400 font-semibold mb-5">Funciones específicas del vertical</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              {v.features.map(f => (
                <div class="card-glass p-5 hover:border-white/15 transition-colors">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg flex items-center justify-center text-brand-400 bg-white/5 flex-shrink-0">
                      <i class={`fa-solid ${f.icon}`}></i>
                    </div>
                    <div>
                      <div class="font-display font-semibold text-sm">{f.name}</div>
                      <div class="text-xs text-ink-400 mt-1 leading-relaxed">{f.desc}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <p class="mt-6 text-xs text-ink-500">
              + Todas las funciones del núcleo SuiteHub según la edición que elijas.
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="section">
    <div class="wrap">
      <div class="card-glass gradient-border text-center p-10 lg:p-14 max-w-3xl mx-auto">
        <h2 class="text-3xl lg:text-4xl font-display font-bold mb-4">
          ¿Tu industria <span class="text-gradient">no está en la lista</span>?
        </h2>
        <p class="text-ink-300 mb-8 max-w-xl mx-auto">
          Si tu industria tiene 50+ negocios potenciales en cualquiera de nuestros mercados (Panamá, USA, Venezuela, España), podemos crear un vertical específico para ti.
          Cuéntanos por WhatsApp y evaluamos.
        </p>
        <a href="https://wa.me/50766326006?text=Mi%20industria%20es%20...%20%C2%BFpueden%20crear%20un%20vertical%3F" target="_blank" rel="noopener" class="btn-primary">
          <i class="fa-brands fa-whatsapp"></i> Cuéntanos tu industria
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
