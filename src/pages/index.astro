---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEdiciones } from '../lib/catalog';

const ediciones = [
  {
    key:    'lite',
    name:   'Edición Lite',
    tagline:'Empieza ya',
    price:  24,
    color:  'from-sky-500/20 to-sky-500/5',
    border: 'border-sky-500/30',
    accent: 'text-sky-400',
    ideal:  'Negocio chico, 1 sucursal, hasta 3 usuarios',
    features: [
      'Clientes, productos, servicios',
      'Cotizaciones y facturas electrónicas',
      'Hasta 500 registros',
      'Soporte por email',
    ],
  },
  {
    key:    'core',
    name:   'Edición Core',
    tagline:'Lo esencial',
    price:  48,
    color:  'from-cyan-500/20 to-cyan-500/5',
    border: 'border-cyan-500/30',
    accent: 'text-cyan-400',
    ideal:  '2 sucursales, 8 usuarios, FE certificada',
    features: [
      'Todo de Lite +',
      'Facturación electrónica DGI',
      'CxC con recibos multi-factura',
      'Inventario + movimientos',
      'Reportes pre-armados',
    ],
  },
  {
    key:     'pro',
    name:    'Edición Pro',
    tagline: 'Más popular',
    price:   96,
    color:   'from-brand-600/30 to-brand-600/5',
    border:  'border-brand-500/50',
    accent:  'text-brand-300',
    featured: true,
    ideal:   'Hasta 5 sucursales, 20 usuarios, automatizaciones',
    features: [
      'Todo de Core +',
      'Multi-sucursal con consolidación',
      'API REST + 100K calls/mes',
      'Automatizaciones programadas',
      'WhatsApp Business integrado',
      'Reportes SQL + plantillas PDF',
    ],
  },
  {
    key:    'enterprise',
    name:   'Edición Enterprise',
    tagline:'Sin límites',
    price:  192,
    color:  'from-amber-500/20 to-amber-500/5',
    border: 'border-amber-500/30',
    accent: 'text-amber-400',
    ideal:  'Sucursales ilimitadas, 50 usuarios incluidos',
    features: [
      'Todo de Pro +',
      'Reportes con IA',
      'White-label completo',
      'API ilimitada',
      'Soporte prioritario 24/7',
      'Onboarding dedicado',
    ],
  },
];

// Precios desde el catálogo canónico del panel (con respaldo local).
const _ed = await getEdiciones();
for (const e of ediciones) {
  const c = _ed[e.key];
  if (!c) continue;
  e.price = c.precio_mes;
  if ('yearly' in e) e.yearly = c.precio_anio;
  if ('priceYearly' in e) e.priceYearly = c.precio_anio;
}

const verticales = [
  { key: 'taller',     name: 'HUB Taller',     desc: 'Talleres mecánicos',         icon: 'fa-screwdriver-wrench' },
  { key: 'carwash',    name: 'HUB Carwash',    desc: 'Autolavados y car wash',     icon: 'fa-spray-can-sparkles' },
  { key: 'restaurant', name: 'HUB Restaurant', desc: 'Restaurantes y bares',       icon: 'fa-utensils' },
  { key: 'pos',        name: 'HUB POS',        desc: 'Caja y cobro para food service', icon: 'fa-cash-register' },
  { key: 'pet',        name: 'HUB Pet',        desc: 'Veterinarias y pet shops',   icon: 'fa-paw' },
  { key: 'lavanderia', name: 'HUB Lavandería', desc: 'Lavanderías profesionales',  icon: 'fa-soap' },
  { key: 'beauty',     name: 'HUB Beauty',     desc: 'Salones de belleza, spas',   icon: 'fa-spa' },
  { key: 'clinic',     name: 'HUB Clinic',     desc: 'Consultorios y clínicas',    icon: 'fa-stethoscope' },
  { key: 'gym',        name: 'HUB Gym',        desc: 'Gimnasios y crossfits',      icon: 'fa-dumbbell' },
  { key: 'inmobiliaria', name: 'HUB Inmobiliaria', desc: 'Bienes raíces',          icon: 'fa-building' },
  { key: 'hotel',      name: 'HUB Hotel',      desc: 'Hoteles boutique',           icon: 'fa-hotel' },
  { key: 'phone',      name: 'HUB Phone',      desc: 'Reparación de celulares',    icon: 'fa-mobile-screen' },
  { key: 'traffic',    name: 'HUB Traffic',    desc: 'Conteo y heatmaps en tienda', icon: 'fa-people-arrows' },
];

const pacs = [
  {
    name: 'Digifact',
    desc: 'PAC certificado DGI con API moderna',
    icon: 'fa-bolt',
    color: 'text-brand-400',
  },
  {
    name: 'The Factory HKA',
    desc: 'Líder regional en facturación electrónica',
    icon: 'fa-industry',
    color: 'text-sky-400',
  },
  {
    name: 'Factura Fácil',
    desc: 'PAC panameño con foco en simplicidad',
    icon: 'fa-receipt',
    color: 'text-emerald-400',
  },
  {
    name: 'eFacturapty',
    desc: 'PAC panameño certificado por la DGI',
    icon: 'fa-file-invoice',
    color: 'text-amber-400',
  },
];

const testimonios = [
  {
    quote: 'Cambiamos de un sistema viejo a Edición Pro y en una semana ya facturábamos electrónicamente sin un solo rechazo de DGI. La diferencia es brutal.',
    author: 'Raúl Romero',
    role:   'Técnico Principal — QS Express',
    initial: 'R',
    logo:    '/images/tallerqsexpress.png',
  },
];

const stats = [
  { num: '24',   label: 'PYMEs activas (Panamá)' },
  { num: '5',    label: 'Países objetivo (PA · US · VE · ES · CO)' },
  { num: '13',   label: 'Verticales especializadas' },
  { num: '<24h', label: 'Tiempo de respuesta soporte' },
];

const tour = [
  { label: 'Mesas',    icon: 'fa-chair',         img: '/images/products/restaurant/shot-mesas.webp',    alt: 'SuiteHub — mapa de mesas del salón en tiempo real' },
  { label: 'Pedido',   icon: 'fa-utensils',      img: '/images/products/restaurant/shot-pedido.webp',   alt: 'SuiteHub — toma de pedido por mesa' },
  { label: 'Cocina',   icon: 'fa-fire-burner',   img: '/images/products/restaurant/shot-cocina.webp',   alt: 'SuiteHub — pantalla de cocina (KDS)' },
  { label: 'Cobro',    icon: 'fa-cash-register', img: '/images/products/restaurant/shot-cobro.webp',    alt: 'SuiteHub — cobro y facturación electrónica' },
  { label: 'Reportes', icon: 'fa-chart-line',    img: '/images/products/restaurant/shot-reportes.webp', alt: 'SuiteHub — reportes de ventas y operación' },
];
---
<BaseLayout
  title="SuiteHub — Suite empresarial multi-país que sí escala"
  description="Producto de PROOQ LLC (USA). Facturación electrónica multi-jurisdicción (DGI Panamá en vivo; SENIAT Venezuela, Facturae España, DIAN Colombia y compliance USA en roadmap 2026), multi-sucursal, automatizaciones, API. Disponible en español e inglés. Desde $24/mes.">

  <!-- ════════════════════════════════════════════════════════════
       HERO
       ════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="aurora" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-grid pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-x-0 top-0 h-[600px] bg-radial-brand pointer-events-none" aria-hidden="true"></div>

    <div class="wrap relative section">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="animate-fade-up">
          <span class="eyebrow">
            <i class="fa-solid fa-bolt mr-1"></i> Suite empresarial multi-país · PA · US · VE · ES · CO
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold leading-[1.05] tracking-tight">
            Suite empresarial<br/>
            <span class="text-gradient">que sí escala</span><br/>
            contigo.
          </h1>
          <p class="mt-6 text-lg text-ink-300 max-w-xl leading-relaxed">
            Plataforma de gestión para PYMEs en <strong class="text-white">Panamá, USA, Venezuela, España y Colombia</strong>.
            Facturación electrónica multi-jurisdicción, multi-sucursal, automatizaciones y API REST.
            <span class="text-brand-300">Desde $24/mes.</span>
          </p>

          <!-- Idiomas badge -->
          <div class="mt-5 inline-flex items-center gap-2 text-xs px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300">
            <i class="fa-solid fa-globe"></i>
            Disponible en <strong class="text-white">Español</strong> e <strong class="text-white">Inglés</strong>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="https://wa.me/50766326006?text=Hola%2C%20quiero%20una%20demo"
               target="_blank" rel="noopener" class="btn-primary text-base">
              <i class="fa-brands fa-whatsapp text-xl"></i>
              Hablar con ventas ahora
            </a>
            <a href="#tiers" class="btn-secondary text-base">
              Ver ediciones y precios
              <i class="fa-solid fa-arrow-down text-xs ml-1"></i>
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-6 text-sm text-ink-400">
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-shield-halved text-emerald-400"></i>
              FE multi-jurisdicción
            </div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-clock text-brand-400"></i>
              Setup en 24h
            </div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-headset text-brand-400"></i>
              Soporte ES / EN
            </div>
          </div>
        </div>

        <!-- Visual: producto real en mockup de browser -->
        <div class="relative animate-fade-in" style="perspective:1200px;">
          <!-- Glow orb -->
          <div class="absolute -inset-10 bg-brand-600/20 rounded-full blur-3xl" aria-hidden="true"></div>

          <div id="hero-tilt" class="tilt relative browser-mock">
            <div class="browser-bar">
              <span class="bg-rose-400/70"></span>
              <span class="bg-amber-400/70"></span>
              <span class="bg-emerald-400/70"></span>
              <span class="ml-3 text-[10px] text-ink-500 truncate">app.suitehub.net · Dashboard</span>
            </div>
            <img src="/images/hubcore2.webp" alt="Panel de SuiteHub — dashboard de gestión empresarial"
                 width="1885" height="931" fetchpriority="high"
                 class="w-full block" />
          </div>

          <!-- Pill flotante: facturación electrónica -->
          <div class="absolute -top-4 -right-2 sm:-right-5 card-glass px-3.5 py-2 flex items-center gap-2 shadow-2xl">
            <i class="fa-solid fa-receipt text-emerald-400"></i>
            <span class="text-xs font-medium">Factura electrónica con CUFE</span>
          </div>

          <!-- Pill flotante: live -->
          <div class="absolute -bottom-5 left-3 sm:-left-5 card-glass px-4 py-2.5 flex items-center gap-3 shadow-2xl">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-xs font-medium">24 negocios facturando hoy</span>
          </div>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="reveal mt-20 lg:mt-28 grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/5">
        {stats.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1} bg-navy-950 p-6 lg:p-8 text-center`}>
            <div class="text-3xl lg:text-4xl font-display font-bold text-white tabular-nums" data-countup={s.num}>{s.num}</div>
            <div class="text-xs uppercase tracking-wider text-ink-400 mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       TOUR DE PRODUCTO (tabs)
       ════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="wrap">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="eyebrow">Un vistazo por dentro</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          Así se ve <span class="text-gradient">SuiteHub en acción.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          Del salón a la cocina, del cobro al reporte — recorré un flujo real de HUB Restaurant.
          Cada vertical se ve y se siente hecha para tu negocio.
        </p>
      </div>

      <div class="reveal max-w-5xl mx-auto" data-tour>
        <!-- Tabs -->
        <div class="flex flex-wrap justify-center gap-2 mb-6" role="tablist" aria-label="Tour de SuiteHub">
          {tour.map((t, i) => (
            <button type="button" role="tab" data-tour-tab={i} aria-selected={i === 0 ? 'true' : 'false'} class="tour-tab">
              <i class={`fa-solid ${t.icon}`}></i> {t.label}
            </button>
          ))}
        </div>

        <!-- Panels -->
        <div class="browser-mock relative">
          <div class="browser-bar">
            <span class="bg-rose-400/70"></span>
            <span class="bg-amber-400/70"></span>
            <span class="bg-emerald-400/70"></span>
            <span class="ml-3 text-[10px] text-ink-500 truncate">app.suitehub.net · HUB Restaurant</span>
          </div>
          {tour.map((t, i) => (
            <img src={t.img} alt={t.alt} width="1440" height="900" loading="lazy"
                 data-tour-panel={i} class={`w-full block ${i === 0 ? '' : 'hidden'}`} />
          ))}
        </div>

        <p class="text-center mt-6 text-sm text-ink-400">
          ¿Querés verla con tus propios datos?
          <a href="https://wa.me/50766326006?text=Hola%2C%20quiero%20una%20demo%20de%20SuiteHub" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-300 font-medium">Pedí una demo en vivo</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       PACs INTEGRADOS
       ════════════════════════════════════════════════════════════ -->
  <section class="py-16 sm:py-20 bg-navy-900/30 border-y border-white/5">
    <div class="wrap">
      <div class="text-center mb-10">
        <span class="eyebrow">Facturación electrónica multi-jurisdicción</span>
        <h2 class="text-2xl sm:text-3xl font-display font-bold">
          Hoy <span class="text-gradient">4 PACs DGI Panamá</span> en producción · Roadmap 2026: SENIAT VE, Facturae ES, DIAN CO, compliance US
        </h2>
        <p class="mt-3 text-sm text-ink-400 max-w-xl mx-auto">
          Tú eliges con cuál PAC trabajar. SuiteHub se conecta directo y maneja todo el flujo XML, CUFE y QR sin que tengas que pensar en regulación. Capa adaptador diseñada para abstraer cualquier jurisdicción.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
        {pacs.map((p, i) => (
          <div class={`reveal reveal-delay-${i + 1} lift card-glass p-6 text-center hover:border-brand-500/30 transition-colors`}>
            <div class={`w-12 h-12 mx-auto rounded-xl bg-white/5 flex items-center justify-center text-2xl mb-3 ${p.color}`}>
              <i class={`fa-solid ${p.icon}`}></i>
            </div>
            <div class="font-display font-semibold text-base">{p.name}</div>
            <p class="text-xs text-ink-400 mt-1.5">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       EDICIONES
       ════════════════════════════════════════════════════════════ -->
  <section id="tiers" class="section relative">
    <div class="wrap">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow">La familia SuiteHub</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          Cuatro ediciones. <span class="text-gradient">Crece sin migrar.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          Empieza con lo básico hoy y sube de edición cuando lo necesites — sin migrar datos,
          sin reaprender, sin downtime. Mismo núcleo, más músculo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {ediciones.map((t, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative rounded-2xl border ${t.border} bg-gradient-to-b ${t.color} p-6 ${t.featured ? 'lg:scale-105 lg:-mt-2 shadow-glow' : 'lift'}`}>
            {t.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-brand-600 text-white text-[10px] font-semibold uppercase tracking-wider rounded-full">
                Más popular
              </span>
            )}
            <div class={`text-xs uppercase tracking-wider ${t.accent} font-semibold mb-2`}>{t.tagline}</div>
            <h3 class="text-2xl font-display font-bold mb-1">{t.name}</h3>
            <p class="text-xs text-ink-400 mb-5 min-h-[36px]">{t.ideal}</p>
            <div class="mb-6">
              <span class="text-4xl font-display font-bold">${t.price}</span>
              <span class="text-sm text-ink-400">/mes</span>
            </div>
            <ul class="space-y-2.5 mb-7 text-sm">
              {t.features.map(f => (
                <li class="flex items-start gap-2">
                  <i class={`fa-solid fa-check ${t.accent} mt-1 text-xs`}></i>
                  <span class="text-ink-200">{f}</span>
                </li>
              ))}
            </ul>
            <a href={`/productos#${t.key}`}
               class={`block w-full text-center py-2.5 rounded-xl text-sm font-medium transition-colors ${t.featured ? 'bg-brand-600 hover:bg-brand-500 text-white' : 'bg-white/5 hover:bg-white/10 text-white border border-white/10'}`}>
              Ver detalles
            </a>
          </div>
        ))}
      </div>

      <p class="text-center mt-10 text-sm text-ink-400">
        16% de descuento pagando anual · Setup gratuito · Sin contratos largos
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       VERTICALES
       ════════════════════════════════════════════════════════════ -->
  <section id="verticales" class="section bg-navy-900/50 relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-600/10 rounded-full blur-3xl"></div>

    <div class="wrap relative">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="eyebrow">Verticales especializados</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold">
          SuiteHub hablada <span class="text-gradient">en tu idioma.</span>
        </h2>
        <p class="mt-5 text-ink-300 leading-relaxed">
          Cada industria tiene su jerga, su flujo, sus necesidades.
          Tomamos SuiteHub y la afinamos para tu negocio específico — lista para usarse desde el día uno.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {verticales.map((v, i) => (
          <a href={`/verticales#${v.key}`}
             class={`reveal reveal-delay-${(i % 4) + 1} group lift card-glass p-5 hover:border-brand-500/30 hover:bg-white/[0.05] transition-all`}>
            <img src={`/images/products/${v.key}/badge.svg`} alt={v.name} class="w-12 h-12 mb-4 group-hover:scale-110 transition-transform" loading="lazy" />
            <h3 class="text-base font-display font-semibold mb-1">{v.name}</h3>
            <p class="text-xs text-ink-400">{v.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/verticales" class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 text-sm font-medium">
          Conoce todos los verticales <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       CASO DE ÉXITO QS EXPRESS
       ════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="wrap">
      <div class="card-glass overflow-hidden grid lg:grid-cols-5 gap-0">
        <div class="lg:col-span-3 p-10 lg:p-14 flex flex-col justify-center">
          <span class="eyebrow">
            <i class="fa-solid fa-star mr-1"></i> Caso de éxito
          </span>
          <h2 class="text-3xl lg:text-4xl font-display font-bold mb-5">
            QS Express triplicó su <span class="text-gradient">capacidad operativa</span>
          </h2>
          <p class="text-ink-300 leading-relaxed mb-8">
            Un taller mecánico en La Chorrera con 20+ años de experiencia migró desde
            Excel y libretas. En 4 semanas ya estaban facturando electrónicamente,
            agendando online y siguiendo cada orden de trabajo en tiempo real.
          </p>

          <div class="grid grid-cols-3 gap-6 mb-8">
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">3×</div>
              <div class="text-xs text-ink-400 mt-1">Más órdenes/día</div>
            </div>
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">0</div>
              <div class="text-xs text-ink-400 mt-1">Rechazos DGI</div>
            </div>
            <div>
              <div class="text-3xl font-display font-bold text-brand-400">4 sem</div>
              <div class="text-xs text-ink-400 mt-1">Para estar 100%</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="/casos#qs-express" class="btn-secondary">
              Leer el caso completo <i class="fa-solid fa-arrow-right text-xs"></i>
            </a>
            <a href="https://tallerqsexpress.com" target="_blank" rel="noopener"
               class="btn-ghost text-sm">
              Ver tallerqsexpress.com <i class="fa-solid fa-external-link text-xs"></i>
            </a>
          </div>
        </div>

        <!-- Visual del caso -->
        <div class="lg:col-span-2 bg-gradient-to-br from-navy-800 to-navy-900 p-10 flex items-center justify-center border-t lg:border-t-0 lg:border-l border-white/5">
          <div class="text-center">
            <img src="/images/tallerqsexpress.png" alt="QS Express" width="300" height="271"
                 class="w-32 mx-auto mb-4 rounded-xl bg-white/5 p-3" />
            <div class="flex items-center justify-center gap-2.5 mb-4">
              <img src="/images/products/taller/badge.svg" alt="HUB Taller" class="w-12 h-12" />
              <span class="font-display font-bold text-xl">HUB Taller</span>
            </div>
            <div class="text-sm text-ink-400">Taller mecánico — La Chorrera</div>
            <div class="mt-4 inline-flex items-center gap-2 text-xs text-emerald-400 bg-emerald-400/10 px-3 py-1.5 rounded-full">
