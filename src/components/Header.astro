---
import { getLocaleFromUrl, useTranslations, localizedHref, alternateHref } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const links = [
  { key: 'home',      label: t('nav.home') },
  { key: 'products',  label: t('nav.products') },
  { key: 'verticals', label: t('nav.verticals') },
  { key: 'cases',     label: t('nav.cases') },
  { key: 'pricing',   label: t('nav.pricing') },
  { key: 'about',     label: t('nav.about') },
  { key: 'contact',   label: t('nav.contact') },
] as const;

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const altLocale = locale === 'es' ? 'en' : 'es';
const altPath = alternateHref(Astro.url.pathname, altLocale);
const homeHref = localizedHref('home', locale);
const demoText = t('wa.text.demo');
---
<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-navy-950/70 border-b border-white/5">
  <nav class="wrap flex items-center justify-between h-20" aria-label="Principal">
    <a href={homeHref} class="flex items-center gap-3 group">
      <img src="/images/products/suite/dark.svg" alt="SuiteHub"
           class="h-14 w-auto transition-opacity group-hover:opacity-90" />
    </a>

    <ul class="hidden lg:flex items-center gap-1">
      {links.map(l => {
        const href = localizedHref(l.key as any, locale);
        const normalized = href.replace(/\/$/, '') || '/';
        const active = current === normalized || (normalized !== '/' && normalized !== homeHref.replace(/\/$/, '') && current.startsWith(normalized));
        return (
          <li>
            <a href={href}
               class={`px-4 py-2 rounded-lg text-sm transition-colors ${active ? 'text-white bg-white/5' : 'text-ink-300 hover:text-white hover:bg-white/5'}`}>
              {l.label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="flex items-center gap-2">
      <!-- Selector ES/EN funcional -->
      <a href={altPath}
         hreflang={altLocale}
         aria-label={t('nav.lang.toggle')}
         class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs text-ink-300 hover:text-white hover:bg-white/5 transition-colors">
        <i class="fa-solid fa-globe text-sm"></i>
        <span class={locale === 'es' ? 'font-medium text-white' : 'text-ink-500'}>ES</span>
        <span class="text-ink-500">/</span>
        <span class={locale === 'en' ? 'font-medium text-white' : 'text-ink-500'}>EN</span>
      </a>

      <a href={`https://wa.me/50766326006?text=${demoText}`}
         target="_blank" rel="noopener"
         class="hidden sm:inline-flex btn-primary text-sm py-2 px-4">
        <i class="fa-brands fa-whatsapp text-base"></i>
        {t('nav.demo')}
      </a>
      <button id="mobile-toggle" class="lg:hidden text-white text-xl p-2" aria-label={t('nav.menu')}>
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-white/5 bg-navy-950/95 backdrop-blur">
    <ul class="wrap py-4 space-y-1">
      {links.map(l => (
        <li>
          <a href={localizedHref(l.key as any, locale)} class="block px-4 py-3 rounded-lg text-ink-200 hover:bg-white/5 hover:text-white">{l.label}</a>
        </li>
      ))}
      <li class="pt-2 flex items-center justify-between gap-3">
        <a href={altPath} class="px-3 py-2 rounded-lg text-sm text-ink-300 hover:bg-white/5 hover:text-white">
          <i class="fa-solid fa-globe"></i> {altLocale.toUpperCase()}
        </a>
        <a href={`https://wa.me/50766326006?text=${demoText}`} target="_blank" rel="noopener" class="flex-1 text-center btn-primary">
          <i class="fa-brands fa-whatsapp"></i> {t('nav.demo')}
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('mobile-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    const open = !menu?.classList.contains('hidden');
    toggle.innerHTML = open ? '<i class="fa-solid fa-xmark"></i>' : '<i class="fa-solid fa-bars"></i>';
  });
</script>
